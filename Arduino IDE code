#include <SPI.h>
#include <MFRC522.h>

#define RST_PIN 22
#define SS_PIN 21

MFRC522 mfrc522(SS_PIN, RST_PIN);
MFRC522::MIFARE_Key key;
MFRC522::StatusCode status;

// Block (hindari 3,7,11)
int blockNama  = 2;
int blockKelas = 4;
int blockNisn  = 5;

// Data harus 16 karakter
byte nama[16]  = "BUDI_SANTOSO   ";
byte kelas[16] = "XII_RPL_1      ";
byte nisn[16]  = "1234567890     ";

byte bufferLen = 18;

void setup() {
  Serial.begin(115200);
  SPI.begin();
  mfrc522.PCD_Init();

  Serial.println("Tempel kartu RFID...");
}

void loop() {

  // Key default
  for (byte i = 0; i < 6; i++) {
    key.keyByte[i] = 0xFF;
  }

  // Deteksi kartu
  if (!mfrc522.PICC_IsNewCardPresent()) return;
  if (!mfrc522.PICC_ReadCardSerial()) return;

  Serial.println("\n=== KARTU TERDETEKSI ===");

  // Tulis data
  Serial.println("Menulis Nama...");
  WriteData(blockNama, nama);

  Serial.println("Menulis Kelas...");
  WriteData(blockKelas, kelas);

  Serial.println("Menulis NISN...");
  WriteData(blockNisn, nisn);

  delay(1000);

  // Buffer baca
  byte readNama[18];
  byte readKelas[18];
  byte readNisn[18];

  Serial.println("\nMembaca Data...");

  ReadData(blockNama, readNama);
  ReadData(blockKelas, readKelas);
  ReadData(blockNisn, readNisn);

  // Tampilkan hasil
  Serial.print("Nama  : ");
  printData(readNama);

  Serial.print("Kelas : ");
  printData(readKelas);

  Serial.print("NISN  : ");
  printData(readNisn);

  Serial.println("\n========================");

  delay(3000);
}

// ================= FUNCTION =================

void WriteData(int block, byte data[]) {

  status = mfrc522.PCD_Authenticate(
    MFRC522::PICC_CMD_MF_AUTH_KEY_A,
    block,
    &key,
    &(mfrc522.uid)
  );

  if (status != MFRC522::STATUS_OK) {
    Serial.print("Auth gagal: ");
    Serial.println(mfrc522.GetStatusCodeName(status));
    return;
  }

  status = mfrc522.MIFARE_Write(block, data, 16);

  if (status != MFRC522::STATUS_OK) {
    Serial.print("Write gagal: ");
    Serial.println(mfrc522.GetStatusCodeName(status));
  } else {
    Serial.println("Berhasil");
  }
}

void ReadData(int block, byte buffer[]) {

  status = mfrc522.PCD_Authenticate(
    MFRC522::PICC_CMD_MF_AUTH_KEY_A,
    block,
    &key,
    &(mfrc522.uid)
  );

  if (status != MFRC522::STATUS_OK) {
    Serial.print("Auth gagal: ");
    Serial.println(mfrc522.GetStatusCodeName(status));
    return;
  }

  status = mfrc522.MIFARE_Read(block, buffer, &bufferLen);

  if (status != MFRC522::STATUS_OK) {
    Serial.print("Read gagal: ");
    Serial.println(mfrc522.GetStatusCodeName(status));
  }
}

void printData(byte data[]) {
  for (int i = 0; i < 16; i++) {
    Serial.write(data[i]);
  }
  Serial.println();
}
