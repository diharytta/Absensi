#include <SPI.h>
#include <MFRC522.h>
#include <Arduino.h>
#include <WiFi.h>
#include <HTTPClient.h>
#include <WiFiClientSecure.h>
#include <WebServer.h>

#define RST_PIN 22
#define SS_PIN 21
#define BUZZER 15

MFRC522 mfrc522(SS_PIN, RST_PIN);
WebServer server(80);

String lastCard = "Belum ada kartu";

// Ganti dengan URL Google Script kamu
const String sheet_url = "https://script.google.com/macros/s/AKfycby3zs295J482kKtk_4hLfSdhr40WWdaE2xotT3LG0AoLh18xZAsfrC-PI8gwd4ipKSerA/exec";

#define WIFI_SSID "http"
#define WIFI_PASSWORD "mapatgawatu"

// ================= WEB HANDLER =================
void handleData() {
  server.send(200, "text/plain", lastCard);
}

void handleRoot() {
  String html = R"rawliteral(
  <!DOCTYPE html>
  <html>
  <head>
    <title>RFID ESP32</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
      body {
        font-family: Arial;
        text-align: center;
        background: #0f172a;
        color: white;
      }
      .card {
        background: #1e293b;
        padding: 20px;
        border-radius: 15px;
        margin: 50px auto;
        width: 300px;
        box-shadow: 0 0 20px rgba(0,0,0,0.5);
      }
      h1 {
        color: #38bdf8;
      }
      #data {
        font-size: 22px;
        margin-top: 20px;
        color: #22c55e;
        font-weight: bold;
      }
    </style>
  </head>
  <body>
    <div class="card">
      <h1>RFID Monitor</h1>
      <p>Last Card UID:</p>
      <div id="data">Loading...</div>
    </div>

    <script>
      setInterval(() => {
        fetch('/data')
          .then(res => res.text())
          .then(data => {
            document.getElementById('data').innerText = data;
          });
      }, 1000);
    </script>
  </body>
  </html>
  )rawliteral";

  server.send(200, "text/html", html);
}

// ================= SETUP =================
void setup() {
  Serial.begin(115200);

  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  Serial.print("Connecting");

  while (WiFi.status() != WL_CONNECTED) {
    Serial.print(".");
    delay(500);
  }

  Serial.println("\nConnected!");
  Serial.print("IP Address: ");
  Serial.println(WiFi.localIP());

  pinMode(BUZZER, OUTPUT);

  SPI.begin();
  mfrc522.PCD_Init();

  server.on("/", handleRoot);
  server.on("/data", handleData);
  server.begin();
}

// ================= LOOP =================
void loop() {
  server.handleClient();

  if (!mfrc522.PICC_IsNewCardPresent()) return;
  if (!mfrc522.PICC_ReadCardSerial()) return;

  // Ambil UID kartu (lebih aman dari read block)
  String uid = "";
  for (byte i = 0; i < mfrc522.uid.size; i++) {
    uid += String(mfrc522.uid.uidByte[i], HEX);
  }

  uid.toUpperCase();
  lastCard = uid;

  Serial.println("Card UID: " + uid);

  // Bunyi buzzer
  digitalWrite(BUZZER, HIGH);
  delay(150);
  digitalWrite(BUZZER, LOW);

  // ================= KIRIM KE GOOGLE SHEET =================
  if (WiFi.status() == WL_CONNECTED) {
    WiFiClientSecure client;
    client.setInsecure();

    String url = sheet_url + "?uid=" + uid;

    HTTPClient https;
    if (https.begin(client, url)) {
      int httpCode = https.GET();

      if (httpCode > 0) {
        Serial.println("Data terkirim ke Google Sheet");
      } else {
        Serial.println("Gagal kirim");
      }
      https.end();
    }
  }

  delay(1000);
}
